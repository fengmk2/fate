{
  "name": "@app/server",
  "version": "0.0.1",
  "private": true,
  "author": "Christoph Nakazawa <christoph.pojer@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git://github.com/nkzw-tech/fate.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply fate-cloudflare --local",
    "db:migrate:remote": "wrangler d1 migrations apply fate-cloudflare --remote",
    "deploy": "wrangler deploy",
    "dev": "pnpm run db:migrate && wrangler dev",
    "dev:setup": "pnpm run db:migrate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nkzw/core": "^1.3.1",
    "@nkzw/fate": "latest",
    "better-auth": "^1.6.13",
    "cf-fate": "latest",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.0.0"
  }
}
